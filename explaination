// ── Helpers ──────────────────────────────────────────────────────────────────
const b  = (color = "CCCCCC") => ({ style: BorderStyle.SINGLE, size: 1, color });
const bs = (c = "CCCCCC")     => ({ top: b(c), bottom: b(c), left: b(c), right: b(c) });
const nb = ()                  => ({ style: BorderStyle.NONE, size: 0, color: "FFFFFF" });
const nbs = ()                 => ({ top: nb(), bottom: nb(), left: nb(), right: nb() });
const cm  = { top: 100, bottom: 100, left: 140, right: 140 };
const cmw = { top: 140, bottom: 140, left: 200, right: 200 };

function sp(n = 120) {
  return new Paragraph({ spacing: { before: n, after: 0 }, children: [new TextRun("")] });
}

function hr(color = TEAL, size = 6) {
  return new Paragraph({
    spacing: { before: 180, after: 180 },
    border: { bottom: { style: BorderStyle.SINGLE, size, color, space: 1 } },
    children: [new TextRun("")]
  });
}

function h1(text) {
  return new Paragraph({
    heading: HeadingLevel.HEADING_1,
    spacing: { before: 400, after: 160 },
    border: { bottom: { style: BorderStyle.SINGLE, size: 10, color: TEAL, space: 8 } },
    children: [new TextRun({ text, font: "Arial", size: 38, bold: true, color: NAVY })]
  });
}

function h2(text, color = NAVY) {
  return new Paragraph({
    heading: HeadingLevel.HEADING_2,
    spacing: { before: 320, after: 100 },
    children: [new TextRun({ text, font: "Arial", size: 28, bold: true, color })]
  });
}

function h3(text, color = BLACK) {
  return new Paragraph({
    heading: HeadingLevel.HEADING_3,
    spacing: { before: 220, after: 80 },
    children: [new TextRun({ text, font: "Arial", size: 23, bold: true, color })]
  });
}

function p(text, opts = {}) {
  const { bold = false, italic = false, color = BLACK, size = 22,
          before = 60, after = 80, align = AlignmentType.LEFT } = opts;
  return new Paragraph({
    alignment: align,
    spacing: { before, after },
    children: [new TextRun({ text, font: "Arial", size, bold, italic, color })]
  });
}

function rp(runs, opts = {}) {
  const { before = 60, after = 80, align = AlignmentType.LEFT } = opts;
  return new Paragraph({
    alignment: align,
    spacing: { before, after },
    children: runs.map(r => new TextRun({ font: "Arial", size: 22, color: BLACK, ...r }))
  });
}

function bullet(text, level = 0, color = BLACK, bold = false) {
  return new Paragraph({
    numbering: { reference: "bullets", level },
    spacing: { before: 50, after: 50 },
    children: [new TextRun({ text, font: "Arial", size: 22, color, bold })]
  });
}

// Box helpers
function box(children, fillColor, leftColor, leftSize = 18) {
  return new Table({
    width: { size: 9360, type: WidthType.DXA },
    columnWidths: [9360],
    rows: [new TableRow({ children: [new TableCell({
      borders: {
        top: b(leftColor),
        bottom: b("DDDDDD"),
        left: { style: BorderStyle.SINGLE, size: leftSize, color: leftColor },
        right: b("DDDDDD")
      },
      shading: { fill: fillColor, type: ShadingType.CLEAR },
      margins: cmw,
      width: { size: 9360, type: WidthType.DXA },
      children
    })] })]
  });
}

// Script block — distinct visual style for spoken words
function scriptBox(label, lines) {
  const labelPara = new Paragraph({
    spacing: { before: 0, after: 80 },
    children: [new TextRun({ text: label, font: "Arial", size: 19, bold: true, color: TEAL, characterSpacing: 100 })]
  });
  const contentParas = lines.map(line => {
    const isStage = line.startsWith("[") && line.endsWith("]");
    return new Paragraph({
      spacing: { before: 0, after: 60 },
      children: [new TextRun({
        text: line,
        font: "Arial",
        size: isStage ? 19 : 22,
        italic: isStage,
        color: isStage ? DGRAY : SCRIPT,
      })]
    });
  });
  return box([labelPara, ...contentParas], "EDF7F4", TEAL, 24);
}

// Q&A block
function qaBox(question, answer, tips = []) {
  const children = [
    new Paragraph({
      spacing: { before: 0, after: 80 },
      children: [new TextRun({ text: "❓  " + question, font: "Arial", size: 22, bold: true, color: NAVY })]
    }),
    new Paragraph({
      spacing: { before: 0, after: tips.length ? 80 : 0 },
      children: [new TextRun({ text: answer, font: "Arial", size: 22, color: SCRIPT })]
    }),
    ...tips.map(t => new Paragraph({
      numbering: { reference: "bullets", level: 0 },
      spacing: { before: 40, after: 40 },
      children: [new TextRun({ text: t, font: "Arial", size: 21, color: SCRIPT })]
    }))
  ];
  return box(children, "F0FBF8", TEAL, 18);
}

function sectionDivider(num, title, subtitle) {
  return new Table({
    width: { size: 9360, type: WidthType.DXA },
    columnWidths: [9360],
    rows: [new TableRow({ children: [new TableCell({
      borders: nbs(),
      shading: { fill: NAVY, type: ShadingType.CLEAR },
      margins: { top: 200, bottom: 200, left: 280, right: 280 },
      width: { size: 9360, type: WidthType.DXA },
      children: [
        new Paragraph({
          spacing: { before: 0, after: 80 },
          children: [
            new TextRun({ text: num + "  ", font: "Arial", size: 48, bold: true, color: TEAL }),
            new TextRun({ text: title.toUpperCase(), font: "Arial", size: 26, bold: true, color: WHITE, characterSpacing: 80 })
          ]
        }),
        subtitle ? new Paragraph({
          spacing: { before: 0, after: 0 },
          children: [new TextRun({ text: subtitle, font: "Arial", size: 20, italic: true, color: DGRAY })]
        }) : null
      ].filter(Boolean)
    })] })]
  });
}

function infoRow(cols) {
  // cols: [{text, color, fill, w}]
  const totalW = cols.reduce((a, c) => a + c.w, 0);
  return new Table({
    width: { size: totalW, type: WidthType.DXA },
    columnWidths: cols.map(c => c.w),
    rows: [new TableRow({ children: cols.map(c => new TableCell({
      borders: nbs(),
      shading: { fill: c.fill || LGRAY, type: ShadingType.CLEAR },
      margins: cmw,
      width: { size: c.w, type: WidthType.DXA },
      children: [new Paragraph({
        spacing: { before: 0, after: 0 },
        children: [new TextRun({ text: c.text, font: "Arial", size: 21, bold: c.bold || false, color: c.color || BLACK })]
      })]
    })) })]
  });
}

